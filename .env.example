# ─── Mercado Livre ──────────────────────────────────────────────────────────
APP_ID=
SECRET_KEY=
ACCESS_TOKEN=
REFRESH_TOKEN=
USER_ID=

# ─── Painel Admin ───────────────────────────────────────────────────────────
PAINEL_USUARIO=admin
# Gere o hash com: npm run senha
PAINEL_SENHA_HASH=
# SESSION_SECRET deve ter no mínimo 32 caracteres
SESSION_SECRET=

# ─── Banco de dados ─────────────────────────────────────────────────────────
# Desenvolvimento (SQLite):
DB_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# Produção (PostgreSQL — Railway/Render):
# DB_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Inteligência Artificial ─────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Email (opcional — notificações ao vendedor) ─────────────────────────────
EMAIL_REMETENTE=
EMAIL_SENHA=
EMAIL_VENDEDOR=

# ─── Ambiente ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
